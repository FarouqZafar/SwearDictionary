# Supabase — get these from your project's Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key_here

# The anon/publishable key (used by the Next.js frontend — public, safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_anon_key_here

# Secret token for POST /api/revalidate (on-demand path revalidation)
REVALIDATION_SECRET=change-me-to-a-long-random-string
